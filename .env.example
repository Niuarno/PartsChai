# ===========================================
# PartsChai - Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in your Vercel dashboard

# ===========================================
# DATABASE (Supabase PostgreSQL)
# ===========================================
# Get these from your Supabase project settings > Database > Connection string
# DATABASE_URL: Use the connection pooling URL (for serverless)
# DIRECT_DATABASE_URL: Use the direct connection URL (for migrations)

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ===========================================
# NEXTAUTH (Authentication)
# ===========================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="https://your-domain.vercel.app"

# ===========================================
# UDDOKTAPAY (Payment Gateway)
# ===========================================
# Get these from your UddoktaPay dashboard
# API Key: Dashboard > Settings > API Credentials
# Base URL: https://uddoktapay.com/api (production) or sandbox URL for testing

UDDOKTAPAY_API_KEY="your-uddoktapay-api-key"
UDDOKTAPAY_BASE_URL="https://uddoktapay.com/api"
UDDOKTAPAY_WEBHOOK_SECRET="your-webhook-secret"

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_NAME="PartsChai"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_DESCRIPTION="Bangladesh's Premier PC Parts Marketplace"

# ===========================================
# OPTIONAL: External Services
# ===========================================
# For image uploads, you can use Supabase Storage or other services
# SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
